WCPROB_DATABASE=wcprob.sqlite
WCPROB_REFRESH_SECONDS=900

# The Odds API requires a key.
WCPROB_ODDS_API_KEY=
WCPROB_ODDS_API_REGIONS=us

# Polymarket is enabled by default through its public Gamma endpoint.
WCPROB_POLYMARKET_ENABLED=true

# Kalshi is opt-in because broad search can return unrelated markets.
WCPROB_KALSHI_ENABLED=false
WCPROB_KALSHI_URL=

# News signal is enabled by default with an RSS search feed.
WCPROB_NEWS_ENABLED=true
WCPROB_NEWS_URL=https://news.google.com/rss/search?q=World%20Cup%202026%20winner
